class Mesh:
    def __init__(self,coordinate,element,numbering= None):
        if numbering is None:
            self.coordinate = coordinate 
            self.element = element
        else:
            self.coordinate = coordinate 
            self.element = element
            self.numbering = numbering-1
    def det_J(self):
        return (self.coordinate[self.element[self.numbering][1]][0]-self.coordinate[self.element[self.numbering][0]][0])*(self.coordinate[self.element[self.numbering][2]][1]-self.coordinate[self.element[self.numbering][0]][1])-(self.coordinate[self.element[self.numbering][1]][1]-self.coordinate[self.element[self.numbering][0]][1])*(self.coordinate[self.element[self.numbering][2]][0]-self.coordinate[self.element[self.numbering][0]][0])
    def min_angle(self):
        a = [self.coordinate[self.element[self.numbering][1]][0]-self.coordinate[self.element[self.numbering][0]][0],self.coordinate[self.element[self.numbering][1]][1]-self.coordinate[self.element[self.numbering][0]][1]]
        b = [self.coordinate[self.element[self.numbering][2]][0]-self.coordinate[self.element[self.numbering][0]][0],self.coordinate[self.element[self.numbering][2]][1]-self.coordinate[self.element[self.numbering][0]][1]]
        c = [self.coordinate[self.element[self.numbering][2]][0]-self.coordinate[self.element[self.numbering][1]][0],self.coordinate[self.element[self.numbering][2]][1]-self.coordinate[self.element[self.numbering][1]][1]]
        return min(np.arccos((a[0]*b[0]+a[1]*b[1])/(np.sqrt(a[0]**2+a[1]**2)*np.sqrt(b[0]**2+b[1]**2))), np.arccos((a[0]*c[0]+a[1]*c[1])/(np.sqrt(a[0]**2+a[1]**2)*np.sqrt(c[0]**2+c[1]**2))), np.arccos((c[0]*b[0]+c[1]*b[1])/(np.sqrt(c[0]**2+c[1]**2)*np.sqrt(b[0]**2+b[1]**2))))
    def anropning(self):
        p = []
        for i in range(len(self.element)):
            a = [self.coordinate[self.element[i][1]][0]-self.coordinate[self.element[i][0]][0],self.coordinate[self.element[i][1]][1]-self.coordinate[self.element[i][0]][1]]
            b = [self.coordinate[self.element[i][2]][0]-self.coordinate[self.element[i][0]][0],self.coordinate[self.element[i][2]][1]-self.coordinate[self.element[i][0]][1]]
            c = [self.coordinate[self.element[i][2]][0]-self.coordinate[self.element[i][1]][0],self.coordinate[self.element[i][2]][1]-self.coordinate[self.element[i][1]][1]]
            if min(np.arccos((a[0]*b[0]+a[1]*b[1])/(np.sqrt(a[0]**2+a[1]**2)*np.sqrt(b[0]**2+b[1]**2))), np.arccos((a[0]*c[0]+a[1]*c[1])/(np.sqrt(a[0]**2+a[1]**2)*np.sqrt(c[0]**2+c[1]**2))), np.arccos((c[0]*b[0]+c[1]*b[1])/(np.sqrt(c[0]**2+c[1]**2)*np.sqrt(b[0]**2+b[1]**2))))<0.1:
                raise TypeError("Bad Angle")
            else:
                p.append(float(self.coordinate[self.element[i][1]][0]-self.coordinate[self.element[i][0]][0])*(self.coordinate[self.element[i][2]][1]-self.coordinate[self.element[i][0]][1])-(self.coordinate[self.element[i][1]][1]-self.coordinate[self.element[i][0]][1])*(self.coordinate[self.element[i][2]][0]-self.coordinate[self.element[i][0]][0]))
        return p
    def f_dash(self):
        anrop = self.anropning()
        q = []
        def f(x,y):
            return 40*x +20*y
        for i in range(len(anrop)):
            q.append(abs(anrop[i])/6*(f(self.coordinate[self.element[i][0]][0],self.coordinate[self.element[i][0]][1])+f(self.coordinate[self.element[i][1]][0],self.coordinate[self.element[i][1]][1])+f(self.coordinate[self.element[i][2]][0],self.coordinate[self.element[i][2]][1])))
        return sum(q)
    def area(self):
        q = []
        for i in range(len(self.element)):
            q.append(1/2*abs(self.coordinate[self.element[i][0]][0]*(self.coordinate[self.element[i][1]][1]-self.coordinate[self.element[i][2]][1])+self.coordinate[self.element[i][1]][0]*(self.coordinate[self.element[i][2]][1]-self.coordinate[self.element[i][0]][1])+self.coordinate[self.element[i][2]][0]*(self.coordinate[self.element[i][0]][1]-self.coordinate[self.element[i][1]][1])))
        return sum(q)
        



